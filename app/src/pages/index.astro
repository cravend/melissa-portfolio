---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../utils/image";
import { getPageCopy, getSiteSettings } from "../utils/sanity";

const [siteSettings, pageCopy] = await Promise.all([
  getSiteSettings(),
  getPageCopy(),
]);
const homeCopy = pageCopy?.home;
const siteTitle = siteSettings?.siteTitle || "Melissa Craven";
const bio =
  siteSettings?.bio ||
  "Melissa Craven shares travel writing, Fulbright teaching resources, stories for kids, and updates about her author work.";
const headshot = siteSettings?.headshot;
const travelDescription =
  homeCopy?.travelDescription ||
  "Stories, reflections, and updates from Melissa's travels.";
const fulbrightDescription =
  homeCopy?.fulbrightDescription ||
  "Updates from Fulbright work, plus resources and ESOL teaching tools.";
const kidsDescription =
  homeCopy?.kidsDescription ||
  "Activities, polls, and educational tours designed for young learners.";
const authorDescription =
  homeCopy?.authorDescription ||
  "Book news, release updates, and writing-related announcements.";
const contactDescription =
  homeCopy?.contactDescription ||
  "Reach out for collaborations, classroom connections, or speaking.";
---

<Layout title={siteTitle}>
  <section
    class="space-y-6 border-b border-orange-200/70 pb-8 dark:border-brand-900/60"
  >
    <h1>Writing, Teaching, and Storytelling</h1>
    <div class="grid gap-6 md:grid-cols-[220px_1fr]">
      {
        headshot ? (
          <figure>
            <img
              class="aspect-square w-full object-cover"
              src={urlFor(headshot).width(720).url()}
              alt={headshot.alt || `${siteTitle} headshot`}
            />
          </figure>
        ) : null
      }
      <p class="max-w-3xl">{bio}</p>
    </div>
  </section>

  <section class="space-y-4" aria-labelledby="sections-heading">
    <h2 id="sections-heading">Explore Sections</h2>
    <div class="divide-y divide-orange-200/70 dark:divide-brand-900/60">
      <section class="space-y-2 py-5" aria-labelledby="travel-preview-heading">
        <h3 id="travel-preview-heading">Travel</h3>
        <p>{travelDescription}</p>
        <p>
          <a class="font-semibold no-underline" href="/travel">Visit Travel</a>
        </p>
      </section>

      <section
        class="space-y-2 py-5"
        aria-labelledby="fulbright-preview-heading"
      >
        <h3 id="fulbright-preview-heading">Fulbright</h3>
        <p>{fulbrightDescription}</p>
        <p>
          <a href="/fulbright">Updates</a> ·{" "}
          <a href="/fulbright/resources">Resources</a> ·{" "}
          <a href="/fulbright/esol">ESOL Tools</a>
        </p>
      </section>

      <section class="space-y-2 py-5" aria-labelledby="kids-preview-heading">
        <h3 id="kids-preview-heading">Kids' Corner</h3>
        <p>{kidsDescription}</p>
        <p>
          <a href="/kids-corner">Home</a> · <a href="/kids-corner/polls"
            >Polls</a
          >{" "}
          · <a href="/kids-corner/tours">Tours</a>
        </p>
      </section>

      <section class="space-y-2 py-5" aria-labelledby="author-preview-heading">
        <h3 id="author-preview-heading">Author</h3>
        <p>{authorDescription}</p>
        <p>
          <a class="font-semibold no-underline" href="/author">Visit Author</a>
        </p>
      </section>

      <section class="space-y-2 py-5" aria-labelledby="contact-preview-heading">
        <h3 id="contact-preview-heading">Contact</h3>
        <p>{contactDescription}</p>
        <p>
          <a class="font-semibold no-underline" href="/contact">Visit Contact</a
          >
        </p>
      </section>
    </div>
  </section>
</Layout>
