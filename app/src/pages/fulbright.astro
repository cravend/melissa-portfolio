---
import Layout from "../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import Breadcrumb from "../components/Breadcrumb.astro";
import { formatDate } from "../utils";
import {
  getPostsByCategory,
  getResourcesByCategory,
  getFulbrightPage,
} from "../utils/sanity";
import { getPostPath } from "../utils/routes";

const [updates, prepResources, esolResources, fulbrightPage] =
  await Promise.all([
    getPostsByCategory("fulbright"),
    getResourcesByCategory("fulbright-prep"),
    getResourcesByCategory("esol"),
    getFulbrightPage(),
  ]);
const intro = fulbrightPage?.intro;
const resourcesDescription = fulbrightPage?.resourcesDescription;
const esolDescription = fulbrightPage?.esolDescription;
---

<Layout title="Fulbright">
  <section class="space-y-2">
    <h1>Fulbright</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content">
          <PortableText value={intro} />
        </div>
      ) : null
    }
    <p>
      <a href="/fulbright/resources">Resources</a> ·{" "}
      <a href="/fulbright/esol">ESOL Tools</a>
    </p>
  </section>

  <section class="space-y-4" aria-labelledby="fulbright-updates-heading">
    <h2 id="fulbright-updates-heading">Updates</h2>
    {
      updates.length ? (
        <ul class="divide-y divide-orange-200/70 dark:divide-brand-900/60">
          {updates.map((post) => (
            <li class="py-5">
              <article class="space-y-3">
                <header class="space-y-1">
                  <h3>
                    <a href={getPostPath(post.slug.current, post.category)}>
                      {post.title ?? "---"}
                    </a>
                  </h3>
                  <p>
                    <time datetime={post.publishedAt || post._createdAt}>
                      {formatDate(post.publishedAt || post._createdAt)}
                    </time>
                  </p>
                </header>
                {post.excerpt ? <p>{post.excerpt}</p> : null}
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p>No Fulbright updates are published yet.</p>
      )
    }
  </section>

  <section
    class="space-y-3 border-t border-orange-200/70 pt-5 dark:border-brand-900/60"
    aria-labelledby="fulbright-resources-heading"
  >
    <h2 id="fulbright-resources-heading">Resources</h2>
    {
      resourcesDescription?.length ? (
        <div class="prose-content">
          <PortableText value={resourcesDescription} />
        </div>
      ) : null
    }
    <p>
      <a href="/fulbright/resources">View all Fulbright resources</a>
    </p>
    <p>{prepResources.length} resources currently available.</p>
  </section>

  <section
    class="space-y-3 border-t border-orange-200/70 pt-5 dark:border-brand-900/60"
    aria-labelledby="fulbright-esol-heading"
  >
    <h2 id="fulbright-esol-heading">ESOL Tools</h2>
    {
      esolDescription?.length ? (
        <div class="prose-content">
          <PortableText value={esolDescription} />
        </div>
      ) : null
    }
    <p>
      <a href="/fulbright/esol">View all ESOL tools</a>
    </p>
    <p>{esolResources.length} ESOL tools currently available.</p>
  </section>
</Layout>
