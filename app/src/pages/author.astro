---
import Layout from "../layouts/Layout.astro";
import SimpleBlockContent from "../components/SimpleBlockContent.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { urlFor } from "../utils/image";
import { getBooks, getAuthorPage } from "../utils/sanity";

const [books, authorPage] = await Promise.all([getBooks(), getAuthorPage()]);
const intro = authorPage?.intro;
const publishedBooks = books.filter((b) => b.status === "published");
const upcomingBooks = books.filter((b) => b.status === "upcoming");
---

<Layout title="Author">
  <section class="space-y-2">
    <h1>Author</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content">
          <SimpleBlockContent value={intro} />
        </div>
      ) : null
    }
  </section>

  {
    publishedBooks.length ? (
      <section class="space-y-5">
        <h2>Published</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          {publishedBooks.map((book) => (
            <article class="group overflow-hidden rounded-2xl border border-orange-200/60 bg-white dark:border-brand-900/40 dark:bg-zinc-900">
              {book.coverImage ? (
                <img
                  class="aspect-[3/4] w-full object-cover rounded-none"
                  src={urlFor(book.coverImage).width(480).url()}
                  alt={book.coverImage?.alt ?? book.title ?? ""}
                />
              ) : null}
              <div class="space-y-3 p-5">
                <h3 class="text-xl font-semibold text-zinc-950 dark:text-zinc-50">
                  {book.title ?? "---"}
                </h3>
                {book.description ? (
                  <p class="text-sm text-zinc-600 dark:text-zinc-400">
                    {book.description}
                  </p>
                ) : null}
                {book.purchaseLinks?.length ? (
                  <div
                    class="flex flex-wrap gap-2"
                    style="font-family: var(--font-sans);"
                  >
                    {book.purchaseLinks.map((link) => (
                      <a
                        href={link.url}
                        class="inline-flex rounded-full border border-brand-400 px-4 py-1.5 text-sm font-medium no-underline text-brand-700 transition-colors hover:bg-brand-50 dark:border-brand-600 dark:text-brand-300 dark:hover:bg-brand-950"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                ) : null}
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null
  }

  {
    upcomingBooks.length ? (
      <section class="space-y-5">
        <h2>Upcoming</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          {upcomingBooks.map((book) => (
            <article class="group overflow-hidden rounded-2xl border border-dashed border-orange-200/80 bg-orange-50/30 dark:border-brand-900/50 dark:bg-zinc-900/50">
              {book.coverImage ? (
                <img
                  class="aspect-[3/4] w-full object-cover rounded-none opacity-80"
                  src={urlFor(book.coverImage).width(480).url()}
                  alt={book.coverImage?.alt ?? book.title ?? ""}
                />
              ) : null}
              <div class="space-y-3 p-5">
                <div class="flex items-center gap-2">
                  <span
                    class="rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-700 dark:bg-brand-950 dark:text-brand-300"
                    style="font-family: var(--font-sans);"
                  >
                    Coming Soon
                  </span>
                </div>
                <h3 class="text-xl font-semibold text-zinc-950 dark:text-zinc-50">
                  {book.title ?? "---"}
                </h3>
                {book.description ? (
                  <p class="text-sm text-zinc-600 dark:text-zinc-400">
                    {book.description}
                  </p>
                ) : null}
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null
  }

  {
    !books.length ? (
      <section class="rounded-2xl border border-dashed border-orange-200/80 bg-orange-50/30 p-8 text-center dark:border-brand-900/50 dark:bg-zinc-900/50">
        <p class="text-zinc-500 dark:text-zinc-400">
          Books are on the way. Check back soon for updates.
        </p>
      </section>
    ) : null
  }
</Layout>
