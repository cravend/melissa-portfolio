---
import Layout from "../../layouts/Layout.astro";
import PostDetail from "../../components/PostDetail.astro";
import { getPostByCategory, getPostsByCategory } from "../../utils/sanity";
import { POST_DETAIL_CATEGORY_ROUTES } from "../../utils/routes";
import { urlFor } from "../../utils/image";
import {
  SITE_URL,
  buildBlogPostingSchema,
  buildBreadcrumbSchema,
} from "../../utils/seo";

export async function getStaticPaths() {
  const posts = await getPostsByCategory("fulbright");

  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const slug = Astro.params.slug as string;
const post = await getPostByCategory(slug, "fulbright");

if (!post) {
  return Astro.redirect("/fulbright", 302);
}

const parentRoute = POST_DETAIL_CATEGORY_ROUTES.fulbright;

const description = post.excerpt ?? undefined;
const ogImage = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).fit("crop").url()
  : undefined;

const blogPostingSchema = buildBlogPostingSchema({
  title: post.title ?? "---",
  datePublished: post.publishedAt ?? post._createdAt,
  description,
  imageUrl: ogImage,
});

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: `${SITE_URL}/` },
  { name: parentRoute.label, url: `${SITE_URL}${parentRoute.href}` },
  {
    name: post.title ?? "---",
    url: `${SITE_URL}${parentRoute.href}/${slug}`,
  },
]);
---

<Layout
  title={post.title ?? "---"}
  description={description}
  ogImage={ogImage}
  lcpImage={post.mainImage
    ? urlFor(post.mainImage).width(640).height(480).fit("max").url()
    : undefined}
  ogType="article"
  articlePublishedAt={post.publishedAt ?? post._createdAt}
  articleModifiedAt={post._updatedAt}
  jsonLd={[blogPostingSchema, breadcrumbSchema]}
>
  <PostDetail
    post={post}
    parentHref={parentRoute.href}
    parentLabel={parentRoute.label}
  />
</Layout>
