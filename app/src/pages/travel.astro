---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import { PortableText } from "astro-portabletext";
import Breadcrumb from "../components/Breadcrumb.astro";
import { getTravelPage, getPostsByCategory } from "../utils/sanity";

const [travelPosts, travelPage] = await Promise.all([
  getPostsByCategory("travel"),
  getTravelPage(),
]);
const intro = travelPage?.intro;
const featured = travelPosts[0];
const rest = travelPosts.slice(1);
---

<Layout title="Travel">
  <section class="space-y-2">
    <h1>Travel</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content max-w-2xl">
          <PortableText value={intro} />
        </div>
      ) : null
    }
  </section>

  {
    featured ? (
      <section class="space-y-5">
        <PostCard post={featured} variant="featured" />
        {rest.length ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : null}
      </section>
    ) : (
      <p>No travel posts are published yet.</p>
    )
  }
</Layout>
