---
import Layout from "../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import Breadcrumb from "../components/Breadcrumb.astro";
import { getContactPage } from "../utils/sanity";

const contactPage = await getContactPage();
const intro = contactPage?.intro;
const contactLinks = contactPage?.contactLinks ?? [];

const iconMap: Record<string, string> = {
  email:
    "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  phone:
    "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
  linkedin:
    "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z",
};

function guessIcon(label: string): string | undefined {
  const lower = label.toLowerCase();
  if (lower.includes("email") || lower.includes("mail")) return iconMap.email;
  if (lower.includes("phone") || lower.includes("call")) return iconMap.phone;
  if (lower.includes("linkedin")) return iconMap.linkedin;
  return undefined;
}
---

<Layout title="Contact">
  <section class="space-y-2">
    <h1>Contact</h1>
    <Breadcrumb />
  </section>

  <section class="max-w-xl space-y-6">
    {
      intro?.length ? (
        <div class="prose-content text-lg leading-8">
          <PortableText value={intro} />
        </div>
      ) : null
    }
    <address class="not-italic">
      <ul class="space-y-3">
        {
          contactLinks.map((link) => {
            const icon = guessIcon(link.label);
            return (
              <li>
                <a
                  href={link.url}
                  class="inline-flex items-center gap-3 rounded-xl border border-orange-200/60 bg-white px-5 py-3 no-underline text-zinc-700 transition-all hover:border-brand-400 hover:shadow-md dark:border-brand-900/40 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-brand-600"
                >
                  {icon ? (
                    <svg
                      class="h-5 w-5 shrink-0 text-brand-500 dark:text-brand-400"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={icon}
                      />
                    </svg>
                  ) : null}
                  <span class="font-medium">{link.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </address>
  </section>
</Layout>
