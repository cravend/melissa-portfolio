---
import Layout from "../layouts/Layout.astro";
import SimpleBlockContent from "../components/SimpleBlockContent.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { urlFor } from "../utils/image";
import { getPostPath } from "../utils/routes";
import {
  getPostsByCategory,
  getLatestPostByCategory,
  getKidsCornerPage,
  orderPollsWithFeaturedFirst,
} from "../utils/sanity";
import { PAGE_META } from "../utils/seo";

const [rawPolls, latestTour, kidsCornerPage] = await Promise.all([
  getPostsByCategory("kids-corner/polls"),
  getLatestPostByCategory("kids-corner/tours"),
  getKidsCornerPage(),
]);
const polls = orderPollsWithFeaturedFirst(rawPolls);
const intro = kidsCornerPage?.intro;
const meta = PAGE_META["/kids-corner"];
---

<Layout title={meta.title} description={meta.description}>
  <section class="space-y-2">
    <h1>Kids' Corner</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content">
          <SimpleBlockContent value={intro} />
        </div>
      ) : null
    }
  </section>

  <div class="flex flex-col gap-6">
    <div class="space-y-4">
      <h2
        class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400"
        style="font-family: var(--font-sans);"
      >
        Polls
      </h2>
      {
        polls.length ? (
          <div class="flex flex-col gap-4">
            {polls.map((poll) => {
              const showImage = !!poll.mainImage;
              return (
                <a
                  href={getPostPath(poll.slug.current, poll.category)}
                  class="group flex gap-0 rounded-2xl border border-orange-200/60 bg-white no-underline overflow-hidden transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
                >
                  {showImage && poll.mainImage ? (
                    <img
                      class="aspect-square w-40 shrink-0 object-cover md:w-48 rounded-l-2xl"
                      src={urlFor(poll.mainImage).width(400).height(400).url()}
                      alt={poll.mainImage.alt ?? poll.title ?? ""}
                    />
                  ) : null}
                  <div class:list={["flex flex-col gap-3 p-6 min-w-0 flex-1"]}>
                    <h3 class="text-xl font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
                      {poll.title ?? "---"}
                    </h3>
                    {poll.excerpt ? (
                      <p class="text-sm text-zinc-600 dark:text-zinc-400">
                        {poll.excerpt}
                      </p>
                    ) : null}
                    <span
                      class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
                      style="font-family: var(--font-sans);"
                    >
                      Read more &rarr;
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <a
            href="/kids-corner"
            class="group flex flex-col gap-3 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
          >
            <h3 class="text-xl font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
              Question of the Week
            </h3>
            <p class="text-sm text-zinc-600 dark:text-zinc-400">
              A new question is coming soon. Check back for this week's prompt.
            </p>
            <span
              class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
              style="font-family: var(--font-sans);"
            >
              View polls &rarr;
            </span>
          </a>
        )
      }
    </div>

    <hr class="border-orange-200/60 dark:border-brand-900/40" />

    {
      latestTour ? (
        <a
          href={getPostPath(latestTour.slug.current, latestTour.category)}
          class="group flex flex-col gap-3 rounded-2xl border border-orange-200/60 bg-white no-underline overflow-hidden transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
        >
          {latestTour.mainImage ? (
            <img
              class="aspect-[16/10] w-full object-cover rounded-none"
              src={urlFor(latestTour.mainImage).width(640).height(400).url()}
              alt={latestTour.mainImage?.alt ?? latestTour.title ?? ""}
            />
          ) : null}
          <div class="flex flex-col gap-2 p-6 pt-0">
            {!latestTour.mainImage ? (
              <p
                class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400"
                style="font-family: var(--font-sans);"
              >
                Latest Tour
              </p>
            ) : null}
            <h2 class="text-xl font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
              {latestTour.title ?? "---"}
            </h2>
            {latestTour.excerpt ? (
              <p class="text-sm text-zinc-600 dark:text-zinc-400">
                {latestTour.excerpt}
              </p>
            ) : null}
            <span
              class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
              style="font-family: var(--font-sans);"
            >
              Explore tour &rarr;
            </span>
          </div>
        </a>
      ) : (
        <a
          href="/kids-corner/tours"
          class="group flex flex-col gap-3 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
        >
          <p
            class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400"
            style="font-family: var(--font-sans);"
          >
            Tours
          </p>
          <h2 class="text-xl font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
            Explore Places & Stories
          </h2>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            Tours for young learners are coming soon.
          </p>
          <span
            class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
            style="font-family: var(--font-sans);"
          >
            Browse tours &rarr;
          </span>
        </a>
      )
    }
  </div>
</Layout>
