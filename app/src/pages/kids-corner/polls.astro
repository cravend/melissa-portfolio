---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import PostCard from "../../components/PostCard.astro";
import SimpleBlockContent from "../../components/SimpleBlockContent.astro";
import { getPostsByCategory, getKidsCornerPage } from "../../utils/sanity";

const [polls, kidsCornerPage] = await Promise.all([
  getPostsByCategory("kids-corner/polls"),
  getKidsCornerPage(),
]);
const pollsDescription = kidsCornerPage?.pollsSectionDescription;
const featured = polls[0];
const rest = polls.slice(1);
---

<Layout title="Kids' Corner Polls">
  <section class="space-y-2">
    <h1>Polls</h1>
    <Breadcrumb />
    {
      pollsDescription?.length ? (
        <div class="prose-content">
          <SimpleBlockContent value={pollsDescription} />
        </div>
      ) : null
    }
  </section>

  {
    featured ? (
      <section class="space-y-5">
        <PostCard post={featured} variant="featured" />
        {rest.length ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : null}
      </section>
    ) : (
      <section class="rounded-2xl border border-dashed border-orange-200/80 bg-orange-50/30 p-8 text-center dark:border-brand-900/50 dark:bg-zinc-900/50">
        <p class="text-zinc-500 dark:text-zinc-400">
          No polls are published yet.
        </p>
      </section>
    )
  }
</Layout>
