---
import Layout from "../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import Breadcrumb from "../components/Breadcrumb.astro";
import { urlFor } from "../utils/image";
import { getBooks, getAuthorPage } from "../utils/sanity";

const [books, authorPage] = await Promise.all([getBooks(), getAuthorPage()]);
const intro = authorPage?.intro;
---

<Layout title="Author">
  <section class="space-y-2">
    <h1>Author</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content">
          <PortableText value={intro} />
        </div>
      ) : null
    }
    {
      books.length ? (
        <ul class="divide-y divide-orange-200/70 dark:divide-brand-900/60">
          {books.map((book) => (
            <li class="py-6">
              <article class="grid gap-6 md:grid-cols-[220px_1fr]">
                {book.coverImage ? (
                  <figure>
                    <img
                      class="aspect-[3/4] w-full object-cover"
                      src={urlFor(book.coverImage).width(720).url()}
                      alt={book.coverImage?.alt ?? "---"}
                    />
                  </figure>
                ) : null}
                <div class="space-y-3">
                  <header class="space-y-2">
                    <h2>{book.title ?? "---"}</h2>
                  </header>
                  {book.description ? <p>{book.description}</p> : null}
                  <dl class="space-y-2">
                    <dt>Status</dt>
                    <dd>
                      {book.status === "published"
                        ? "Published"
                        : book.status === "upcoming"
                          ? "Upcoming"
                          : "---"}
                    </dd>
                    {book.purchaseLinks?.length ? (
                      <>
                        <dt>Purchase Links</dt>
                        <dd>
                          <ul class="list-disc pl-5">
                            {book.purchaseLinks.map((link) => (
                              <li>
                                <a href={link.url}>{link.label}</a>
                              </li>
                            ))}
                          </ul>
                        </dd>
                      </>
                    ) : null}
                  </dl>
                </div>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p>No books are listed yet.</p>
      )
    }
  </section>
</Layout>
