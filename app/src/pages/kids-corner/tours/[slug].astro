---
import type { InferGetStaticParamsType } from "astro";
import { PortableText } from "astro-portabletext";
import Layout from "../../../layouts/Layout.astro";
import { urlFor } from "../../../utils/image";
import { getTour, getTours } from "../../../utils/sanity";

export async function getStaticPaths() {
  const tours = await getTours();

  return tours.map((tour) => ({
    params: { slug: tour.slug.current },
  }));
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
const { slug } = Astro.params as Params;

const tour = await getTour(slug);
---

<Layout title={tour.title || "Tour Entry"}>
  <article>
    <header>
      <h1>{tour.title || "Untitled tour"}</h1>
      {tour.description ? <p>{tour.description}</p> : null}
      {
        tour.location ? (
          <dl>
            <dt>Location</dt>
            <dd>{tour.location}</dd>
          </dl>
        ) : null
      }
    </header>

    {
      tour.gallery?.length ? (
        <section aria-labelledby="tour-gallery-heading">
          <h2 id="tour-gallery-heading">Gallery</h2>
          <ul>
            {tour.gallery.map((image) => (
              <li>
                <figure>
                  <img
                    src={urlFor(image).width(1200).url()}
                    alt={
                      image.alt || image.caption || tour.title || "Tour image"
                    }
                  />
                  {image.caption ? (
                    <figcaption>{image.caption}</figcaption>
                  ) : null}
                </figure>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    {
      tour.body?.length ? (
        <section aria-labelledby="tour-story-heading">
          <h2 id="tour-story-heading">Tour Story</h2>
          <PortableText value={tour.body} />
        </section>
      ) : null
    }
  </article>
</Layout>
