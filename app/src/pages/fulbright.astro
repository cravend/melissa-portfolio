---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import ResourceList from "../components/ResourceList.astro";
import SimpleBlockContent from "../components/SimpleBlockContent.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import {
  getPostsByCategory,
  getResources,
  getFulbrightPage,
} from "../utils/sanity";

const [updates, resources, fulbrightPage] = await Promise.all([
  getPostsByCategory("fulbright"),
  getResources(),
  getFulbrightPage(),
]);
const intro = fulbrightPage?.intro;
const vignettesDescription = fulbrightPage?.vignettesDescription;
const resourcesDescription = fulbrightPage?.resourcesDescription;
const disclaimer = fulbrightPage?.disclaimer;
const featured = updates[0];
const moreUpdates = updates.slice(1);
---

<Layout title="Fulbright">
  <section class="space-y-2">
    <h1>Fulbright</h1>
    <Breadcrumb />
    {
      intro?.length ? (
        <div class="prose-content">
          <SimpleBlockContent value={intro} />
        </div>
      ) : null
    }
  </section>

  {
    featured ? (
      <section class="space-y-5">
        <h2>Vignettes</h2>
        {vignettesDescription?.length ? (
          <div class="prose-content">
            <SimpleBlockContent value={vignettesDescription} />
          </div>
        ) : null}
        <PostCard post={featured} variant="featured" />
        {moreUpdates.length ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {moreUpdates.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : null}
      </section>
    ) : (
      <section class="space-y-4">
        <h2>Vignettes</h2>
        {vignettesDescription?.length ? (
          <div class="prose-content">
            <SimpleBlockContent value={vignettesDescription} />
          </div>
        ) : null}
        <section class="rounded-2xl border border-dashed border-orange-200/80 bg-orange-50/30 p-8 text-center dark:border-brand-900/50 dark:bg-zinc-900/50">
          <p class="text-zinc-500 dark:text-zinc-400">
            No vignettes are published yet.
          </p>
        </section>
      </section>
    )
  }

  <section
    class="space-y-5 border-t border-orange-200/70 pt-8 dark:border-brand-900/60"
  >
    <div class="flex items-baseline justify-between gap-4">
      <h2>Resources</h2>
      {
        resources.length ? (
          <a
            href="/fulbright/resources"
            class="text-sm font-medium no-underline text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
            style="font-family: var(--font-sans);"
          >
            View all &rarr;
          </a>
        ) : null
      }
    </div>
    {
      resourcesDescription?.length ? (
        <div class="prose-content">
          <SimpleBlockContent value={resourcesDescription} />
        </div>
      ) : null
    }
    <ResourceList
      resources={resources}
      emptyMessage="No resources are published yet."
    />
    {
      disclaimer?.length ? (
        <div class="prose-content pt-6">
          <SimpleBlockContent value={disclaimer} />
        </div>
      ) : null
    }
  </section>
</Layout>
