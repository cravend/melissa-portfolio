---
import { getPostBySlug, getPosts } from "../../utils/sanity";
import {
  isPostDetailCategory,
  POST_DETAIL_CATEGORY_ROUTES,
} from "../../utils/routes";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const slug = Astro.params.slug as string;
const post = await getPostBySlug(slug);

if (!post?.category) {
  return Astro.redirect("/", 302);
}

if (!isPostDetailCategory(post.category)) {
  return Astro.redirect("/", 302);
}

const categoryRoute = POST_DETAIL_CATEGORY_ROUTES[post.category];
---

return Astro.redirect(`${categoryRoute.href}/${slug}`, 301);
