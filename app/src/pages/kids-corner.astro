---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { getActivePoll, getLatestTour, getPageCopy } from "../utils/sanity";

const [activePoll, latestTour, pageCopy] = await Promise.all([
  getActivePoll(),
  getLatestTour(),
  getPageCopy(),
]);
const kidsCopy = pageCopy?.kidsCorner;
const intro =
  kidsCopy?.intro ||
  "Explore weekly questions, classroom-friendly polls, and student tours.";
const pollsSectionDescription =
  kidsCopy?.pollsSectionDescription ||
  "Share your answer and compare ideas with other kids.";
---

<Layout title="Kids' Corner">
  <section class="space-y-2">
    <h1>Kids' Corner</h1>
    <Breadcrumb />
    <p class="max-w-3xl">{intro}</p>
    <p>
      <a href="/kids-corner/polls">Polls</a> ·{" "}
      <a href="/kids-corner/tours">Tours</a>
    </p>
  </section>

  <section
    class="space-y-3 border-t border-orange-200/70 pt-5 dark:border-brand-900/60"
    aria-labelledby="question-week-heading"
  >
    <h2 id="question-week-heading">Question of the Week</h2>
    {
      activePoll?.question ? (
        <p>{activePoll.question}</p>
      ) : (
        <p>A new question is coming soon. Check back for this week's prompt.</p>
      )
    }
    <p><a href="/kids-corner/polls">Go to poll questions</a></p>
  </section>

  <section
    class="space-y-3 border-t border-orange-200/70 pt-5 dark:border-brand-900/60"
    aria-labelledby="latest-tour-heading"
  >
    <h2 id="latest-tour-heading">Latest Tour</h2>
    {
      latestTour ? (
        <article class="space-y-2">
          <h3>
            <a href={`/kids-corner/tours/${latestTour.slug.current}`}>
              {latestTour.title || "Untitled tour"}
            </a>
          </h3>
          {latestTour.description ? <p>{latestTour.description}</p> : null}
          {latestTour.location ? (
            <dl>
              <dt>Location</dt>
              <dd>{latestTour.location}</dd>
            </dl>
          ) : null}
        </article>
      ) : (
        <p>No tours are published yet.</p>
      )
    }
    <p><a href="/kids-corner/tours">Browse all tours</a></p>
  </section>

  <section
    class="space-y-3 border-t border-orange-200/70 pt-5 dark:border-brand-900/60"
    aria-labelledby="poll-teaser-heading"
  >
    <h2 id="poll-teaser-heading">Polls</h2>
    <p>{pollsSectionDescription}</p>
    {
      activePoll?.options?.length ? (
        <article class="space-y-2">
          <h3>{activePoll.question || "Current poll"}</h3>
          <ul class="list-disc pl-5">
            {activePoll.options.map((option) => (
              <li>{option.label || "Unnamed option"}</li>
            ))}
          </ul>
        </article>
      ) : (
        <p>Poll options will appear here when a poll is active.</p>
      )
    }
    <p><a href="/kids-corner/polls">Visit polls</a></p>
  </section>
</Layout>
