---
import { PortableText } from "astro-portabletext";
import Layout from "../../../layouts/Layout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import PortableTextImage from "../../../components/PortableTextImage.astro";
import { urlFor } from "../../../utils/image";
import { getTour, getTours } from "../../../utils/sanity";

const portableTextComponents = { type: { image: PortableTextImage } };

export async function getStaticPaths() {
  const tours = await getTours();

  return tours.map((tour) => ({
    params: { slug: tour.slug.current },
  }));
}

const { slug } = Astro.params;

const tour = await getTour(slug);
---

<Layout title={tour.title ?? "---"}>
  <article class="space-y-6">
    <header class="space-y-3">
      <h1>{tour.title ?? "---"}</h1>
      <Breadcrumb currentLabel={tour.title ?? "---"} />
      {tour.description ? <p>{tour.description}</p> : null}
      {
        tour.location ? (
          <dl class="space-y-1">
            <dt>Location</dt>
            <dd>{tour.location}</dd>
          </dl>
        ) : null
      }
    </header>

    {
      tour.gallery?.length ? (
        <section class="space-y-3" aria-labelledby="tour-gallery-heading">
          <h2 id="tour-gallery-heading">Gallery</h2>
          <ul class="grid gap-4 md:grid-cols-2">
            {tour.gallery.map((image) => (
              <li class="space-y-2 border-t border-orange-200/70 pt-5 dark:border-brand-900/60">
                <figure class="space-y-2">
                  <img
                    class="aspect-[16/10] w-full object-cover"
                    src={urlFor(image).width(1200).url()}
                    alt={image.alt ?? image.caption ?? tour.title ?? "---"}
                  />
                  {image.caption ? (
                    <figcaption>{image.caption}</figcaption>
                  ) : null}
                </figure>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    {
      tour.body?.length ? (
        <section class="prose-content" aria-labelledby="tour-story-heading">
          <h2 id="tour-story-heading">Tour Story</h2>
          <PortableText value={tour.body} components={portableTextComponents} />
        </section>
      ) : null
    }
  </article>
</Layout>
