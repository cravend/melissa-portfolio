---
import { ViewTransitions } from "astro:transitions";
import { getSiteSettings, getContactPage } from "../utils/sanity";
import { NAV_ITEMS } from "../utils/routes";
import { urlFor } from "../utils/image";
import { SITE_URL } from "../utils/seo";
import "../styles/global.css";

import serif400 from "@fontsource/ibm-plex-serif/files/ibm-plex-serif-latin-400-normal.woff2?url";
import sans400 from "@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lcpImage?: string;
  ogType?: "website" | "article";
  articlePublishedAt?: string;
  articleModifiedAt?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  ogImage,
  lcpImage,
  ogType = "website",
  articlePublishedAt,
  articleModifiedAt,
  jsonLd,
} = Astro.props;
const [siteSettings, contactPage] = await Promise.all([
  getSiteSettings(),
  getContactPage(),
]);
const brandName = siteSettings?.brandName ?? siteSettings?.siteTitle ?? "---";
const footerText = siteSettings?.footerText ?? "---";
const contactLinks = contactPage?.contactLinks ?? [];
const pathname = Astro.url.pathname;

const canonicalURL = new URL(pathname, SITE_URL).href;
const defaultOgImage = siteSettings?.headshot?.asset
  ? urlFor(siteSettings.headshot).width(1200).height(630).fit("crop").url()
  : undefined;
const resolvedOgImage = ogImage ?? defaultOgImage;
const fullTitle = pathname === "/" ? title : `${title} | Melissa Craven`;

const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href={serif400}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={sans400}
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      lcpImage ? (
        <link rel="preload" href={lcpImage} as="image" fetchpriority="high" />
      ) : null
    }
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    {
      description ? (
        <meta property="og:description" content={description} />
      ) : null
    }
    {
      resolvedOgImage ? (
        <meta property="og:image" content={resolvedOgImage} />
      ) : null
    }
    <meta property="og:site_name" content="Melissa Craven" />
    {
      ogType === "article" && articlePublishedAt ? (
        <meta property="article:published_time" content={articlePublishedAt} />
      ) : null
    }
    {
      ogType === "article" && articleModifiedAt ? (
        <meta property="article:modified_time" content={articleModifiedAt} />
      ) : null
    }
    {
      jsonLd ? (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(jsonLd)}
        />
      ) : null
    }
    <ViewTransitions />
  </head>
  <body>
    <div class="site-shell flex min-h-screen flex-col gap-6">
      <header class="soft-divider border-b py-3">
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
        >
          <p
            class="site-brand text-2xl leading-none font-bold tracking-tight text-zinc-950 dark:text-zinc-50"
          >
            <a class="no-underline" href="/">{brandName}</a>
          </p>
          <nav aria-label="Main" class="w-full sm:w-auto">
            <ul
              class="flex flex-wrap items-center gap-x-1 gap-y-1 space-y-0 sm:justify-end"
            >
              {
                NAV_ITEMS.map((item) => (
                  <li>
                    <a
                      class:list={[
                        "site-nav-link",
                        isActive(item.href) && "site-nav-link-active",
                      ]}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </header>
      <main class="flex-1 space-y-8">
        <slot />
      </main>
      <footer class="soft-divider border-t pt-6">
        <div
          class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="site-meta text-sm">{footerText}</p>
          {
            contactLinks.length ? (
              <address class="not-italic site-meta">
                <ul class="flex flex-wrap gap-x-4 gap-y-1 space-y-0 text-sm text-zinc-500 dark:text-zinc-400">
                  {contactLinks.map((link) => (
                    <li class="space-y-0">
                      <a
                        href={link.url}
                        class="no-underline hover:text-brand-800 dark:hover:text-brand-200"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </address>
            ) : null
          }
        </div>
      </footer>
    </div>
  </body>
</html>
