---
import { ViewTransitions } from "astro:transitions";
import { getSiteSettings, getContactPage } from "../utils/sanity";
import { NAV_ITEMS } from "../utils/routes";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const [siteSettings, contactPage] = await Promise.all([
  getSiteSettings(),
  getContactPage(),
]);
const brandName = siteSettings?.brandName ?? siteSettings?.siteTitle ?? "---";
const footerText = siteSettings?.footerText ?? "---";
const contactLinks = contactPage?.contactLinks ?? [];
const pathname = Astro.url.pathname;

const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <div class="site-shell flex min-h-screen flex-col gap-6">
      <header class="soft-divider border-b py-3">
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
        >
          <p
            class="site-brand text-2xl leading-none font-bold tracking-tight text-zinc-950 dark:text-zinc-50"
          >
            <a class="no-underline" href="/">{brandName}</a>
          </p>
          <nav aria-label="Main" class="w-full sm:w-auto">
            <ul
              class="flex flex-wrap items-center gap-x-1 gap-y-1 space-y-0 sm:justify-end"
            >
              {
                NAV_ITEMS.map((item) => (
                  <li>
                    <a
                      class:list={[
                        "site-nav-link",
                        isActive(item.href) && "site-nav-link-active",
                      ]}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </header>
      <main class="flex-1 space-y-8">
        <slot />
      </main>
      <footer class="soft-divider border-t pt-6">
        <div
          class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="site-meta text-sm">{footerText}</p>
          {
            contactLinks.length ? (
              <address class="not-italic site-meta">
                <ul class="flex flex-wrap gap-x-4 gap-y-1 space-y-0 text-sm text-zinc-500 dark:text-zinc-400">
                  {contactLinks.map((link) => (
                    <li class="space-y-0">
                      <a
                        href={link.url}
                        class="no-underline hover:text-brand-600 dark:hover:text-brand-300"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </address>
            ) : null
          }
        </div>
      </footer>
    </div>
  </body>
</html>
