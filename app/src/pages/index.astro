---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import SimpleBlockContent from "../components/SimpleBlockContent.astro";
import { urlFor } from "../utils/image";
import { getPostPath } from "../utils/routes";
import {
  getSiteSettings,
  getFeaturedPosts,
  getLatestPostByCategory,
} from "../utils/sanity";

const [siteSettings, allPosts, latestTour] = await Promise.all([
  getSiteSettings(),
  getFeaturedPosts(),
  getLatestPostByCategory("kids-corner/tours"),
]);

const homeCopy = siteSettings?.home;
const siteTitle = siteSettings?.siteTitle ?? "---";
const bio = siteSettings?.bio;
const headshot = siteSettings?.headshot;
const headline = homeCopy?.headline ?? "Writing, Teaching, and Storytelling";

const recentPosts = allPosts
  .filter((p) => p.category === "fulbright" || p.category === "travel")
  .slice(0, 4);
const featuredPost = recentPosts[0];
const morePosts = recentPosts.slice(1);
---

<Layout title={siteTitle}>
  <section class="relative space-y-6 pb-10">
    <div class="grid items-center gap-8 md:grid-cols-[280px_1fr]">
      {
        headshot?.asset ? (
          <figure>
            <img
              class="aspect-square w-full object-cover shadow-lg"
              src={urlFor(headshot).width(560).url()}
              alt={headshot.alt}
            />
          </figure>
        ) : null
      }
      <div class="space-y-4">
        <h1>{headline}</h1>
        {
          bio?.length ? (
            <div class="prose-content text-lg leading-8 text-zinc-600 dark:text-zinc-300">
              <SimpleBlockContent value={bio} />
            </div>
          ) : null
        }
        <a
          href="/contact"
          class="inline-flex rounded-full border border-brand-400 px-4 py-2 text-sm font-medium no-underline text-brand-700 transition-colors hover:bg-brand-50 dark:border-brand-600 dark:text-brand-300 dark:hover:bg-brand-950"
        >
          Contact
        </a>
      </div>
    </div>
  </section>

  {
    featuredPost ? (
      <section class="space-y-6 border-t border-orange-200/70 pt-8 dark:border-brand-900/60">
        <h2>Latest</h2>
        <PostCard post={featuredPost} variant="featured" />
        {morePosts.length ? (
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {morePosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : null}
      </section>
    ) : null
  }

  <section
    class="space-y-5 border-t border-orange-200/70 pt-8 dark:border-brand-900/60"
  >
    <h2>Explore</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <a
        href="/fulbright"
        class="group relative flex flex-col gap-2 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
      >
        <h3
          class="text-lg font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300"
        >
          Fulbright
        </h3>
        {
          homeCopy?.fulbrightDescription?.length ? (
            <div class="text-sm leading-6 text-zinc-600 dark:text-zinc-400 prose-content">
              <SimpleBlockContent value={homeCopy.fulbrightDescription} />
            </div>
          ) : null
        }
        <span
          class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
          style="font-family: var(--font-sans);"
          >Vignettes & Resources &rarr;</span
        >
      </a>

      <a
        href="/kids-corner"
        class="group relative flex flex-col gap-2 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
      >
        <h3
          class="text-lg font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300"
        >
          Kids' Corner
        </h3>
        {
          homeCopy?.kidsDescription?.length ? (
            <div class="text-sm leading-6 text-zinc-600 dark:text-zinc-400 prose-content">
              <SimpleBlockContent value={homeCopy.kidsDescription} />
            </div>
          ) : null
        }
        <span
          class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
          style="font-family: var(--font-sans);">Polls & Tours &rarr;</span
        >
      </a>

      {
        latestTour ? (
          <a
            href={getPostPath(latestTour.slug.current, latestTour.category)}
            class="group relative flex flex-col gap-2 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
          >
            <p
              class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400"
              style="font-family: var(--font-sans);"
            >
              Latest Tour
            </p>
            <h3 class="text-lg font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
              {latestTour.title ?? "---"}
            </h3>
            {latestTour.excerpt ? (
              <p class="text-sm leading-6 text-zinc-600 dark:text-zinc-400">
                {latestTour.excerpt}
              </p>
            ) : null}
            <span
              class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
              style="font-family: var(--font-sans);"
            >
              Read more &rarr;
            </span>
          </a>
        ) : (
          <a
            href="/author"
            class="group relative flex flex-col gap-2 rounded-2xl border border-orange-200/60 bg-white p-6 no-underline transition-shadow hover:shadow-lg dark:border-brand-900/40 dark:bg-zinc-900"
          >
            <h3 class="text-lg font-semibold text-zinc-950 transition-colors group-hover:text-brand-700 dark:text-zinc-50 dark:group-hover:text-brand-300">
              Author
            </h3>
            {homeCopy?.authorDescription?.length ? (
              <div class="text-sm leading-6 text-zinc-600 dark:text-zinc-400 prose-content">
                <SimpleBlockContent value={homeCopy.authorDescription} />
              </div>
            ) : null}
            <span
              class="mt-auto pt-2 text-sm font-medium text-brand-600 dark:text-brand-400"
              style="font-family: var(--font-sans);"
            >
              Books & News &rarr;
            </span>
          </a>
        )
      }
    </div>
  </section>
</Layout>
