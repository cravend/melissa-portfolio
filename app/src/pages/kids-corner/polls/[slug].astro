---
import Layout from "../../../layouts/Layout.astro";
import PostDetail from "../../../components/PostDetail.astro";
import { getPostByCategory, getPostsByCategory } from "../../../utils/sanity";

export async function getStaticPaths() {
  const posts = await getPostsByCategory("kids-corner/polls");

  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const slug = Astro.params.slug as string;
const post = await getPostByCategory(slug, "kids-corner/polls");

if (!post) {
  return Astro.redirect("/kids-corner", 302);
}
---

<Layout title={post.title ?? "---"}>
  <PostDetail
    post={post}
    parentHref="/kids-corner"
    parentLabel="Kids' Corner"
  />
</Layout>
