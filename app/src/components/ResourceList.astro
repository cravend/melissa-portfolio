---
import { PortableText } from "astro-portabletext";
import PortableTextImage from "./PortableTextImage.astro";
import type { Resource } from "../utils/sanity";

interface Props {
  resources: Resource[];
  emptyMessage: string;
}

const { resources, emptyMessage } = Astro.props;

const portableTextComponents = { type: { image: PortableTextImage } };
---

{
  resources.length ? (
    <div class="grid gap-5 sm:grid-cols-2">
      {resources.map((resource) => {
        const resolvedTitle = resource.title ?? "---";
        return (
          <article class="flex flex-col gap-4 rounded-2xl border border-orange-200/60 bg-white p-6 dark:border-brand-900/40 dark:bg-zinc-900">
            <h2 class="text-xl font-semibold text-zinc-950 dark:text-zinc-50">
              {resolvedTitle}
            </h2>
            {resource.description ? (
              <p class="text-sm text-zinc-600 dark:text-zinc-400">
                {resource.description}
              </p>
            ) : null}
            {resource.body ? (
              <div class="prose-content text-sm">
                <PortableText
                  value={resource.body}
                  components={portableTextComponents}
                />
              </div>
            ) : null}
            {resource.downloads?.length ? (
              <div class="mt-auto space-y-2 border-t border-orange-100 pt-4 dark:border-brand-900/30">
                <p
                  class="text-xs font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400"
                  style="font-family: var(--font-sans);"
                >
                  Downloads
                </p>
                <ul class="space-y-1.5">
                  {resource.downloads.map((download) => (
                    <li>
                      {download.url ? (
                        <a
                          href={download.url}
                          class="inline-flex items-center gap-2 text-sm font-medium"
                        >
                          <svg
                            class="h-4 w-4 shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                            />
                          </svg>
                          {download.label ?? "---"}
                        </a>
                      ) : (
                        <span class="text-sm text-zinc-500">
                          {download.label ?? "---"}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ) : null}
          </article>
        );
      })}
    </div>
  ) : (
    <section class="rounded-2xl border border-dashed border-orange-200/80 bg-orange-50/30 p-8 text-center dark:border-brand-900/50 dark:bg-zinc-900/50">
      <p class="text-zinc-500 dark:text-zinc-400">{emptyMessage}</p>
    </section>
  )
}
